# Copia este archivo a .env.local y rellena los valores.

# Raíz del proyecto Supabase (sin slash final): https://<ref>.supabase.co
# - Vacío  -> los assets se sirven localmente desde /public/assets
# - Configurado -> assets desde el bucket público "assets" de ese proyecto.
# Los buckets (assets, data, ...) se nombran en código, no aquí.
NEXT_PUBLIC_SUPABASE_URL=

# Anon public key del proyecto Supabase (pública por diseño).
# Necesaria solo para listar el contenido del bucket en /storage-check.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
